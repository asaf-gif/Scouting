# Neo4j connection
# Local:  neo4j://localhost:7687
# Aura:   neo4j+s://<your-aura-id>.databases.neo4j.io
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Tavily Search API (free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-...

# Shared data folder (optional — for team use via Google Drive sync)
# Point this to your locally-synced shared Google Drive folder.
# All changelog / audit log files will be read and written there.
# Leave commented out to use the local ./data/ directory instead.
# macOS example:  /Users/yourname/Google Drive/My Drive/scouting-data
# Windows example: C:\Users\yourname\Google Drive\My Drive\scouting-data
# SHARED_DATA_PATH=/path/to/your/shared/drive/folder
